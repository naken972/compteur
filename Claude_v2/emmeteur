#include <bluefruit.h>
#include "nrf_gpio.h"

#define BTN1 D0 // Team 1
#define BTN2 D1 // Team 2
#define BTN3 D2 // Undo

#define LONG_PRESS_MS 3000
#define ACTIVE_WINDOW 2000

// ================= ADVERTISING BLE =================
void majBLE(uint8_t code) {
  // Manufacturer Data avec Company ID (0xFFFF = test/prototype)
  uint8_t mfgData[3] = {0xFF, 0xFF, code};

  Bluefruit.Advertising.stop();
  Bluefruit.Advertising.clearData();
  Bluefruit.Advertising.addFlags(BLE_GAP_ADV_FLAGS_LE_ONLY_GENERAL_DISC_MODE);
  // Pas de addName() : économise 9 bytes dans le paquet ADV, le récepteur filtre par MAC
  Bluefruit.Advertising.addData(BLE_GAP_AD_TYPE_MANUFACTURER_SPECIFIC_DATA, mfgData, 3);
  Bluefruit.Advertising.setInterval(32, 32); // ~20ms, réactif
  Bluefruit.Advertising.start(0);
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  // Lire le latch GPIO pour savoir quel bouton a réveillé le MCU
  uint32_t latch = NRF_P0->LATCH;
  NRF_P0->LATCH = latch; // Clear le latch

  pinMode(BTN1, INPUT_PULLUP);
  pinMode(BTN2, INPUT_PULLUP);
  pinMode(BTN3, INPUT_PULLUP);

  Bluefruit.begin();
  Bluefruit.setTxPower(8);       // Max nRF52840 = +8 dBm
  Bluefruit.setName("NRF_BTN");  // Nom interne (pas diffusé dans ADV)
  Bluefruit.autoConnLed(false);

  uint32_t dernierClic = millis();

  while (millis() - dernierClic < ACTIVE_WINDOW) {

    uint8_t activeBtn = 0;

    // Détection par latch (wake-up) ou lecture directe (appui pendant la fenêtre active)
    if      (!digitalRead(BTN1) || (latch & (1 << g_ADigitalPinMap[BTN1]))) activeBtn = 1;
    else if (!digitalRead(BTN2) || (latch & (1 << g_ADigitalPinMap[BTN2]))) activeBtn = 2;
    else if (!digitalRead(BTN3) || (latch & (1 << g_ADigitalPinMap[BTN3]))) activeBtn = 3;

    latch = 0; // Le latch ne sert qu'au premier tour

    if (activeBtn != 0) {
      Serial.println("\n--- NOUVELLE ACTION ---");
      Serial.print("Bouton detecte : ");
      Serial.println(activeBtn);

      // Affichage MAC pour debug
      ble_gap_addr_t mac = Bluefruit.getAddr();
      Serial.print("MAC : ");
      for (int i = 5; i >= 0; i--) {
        if (mac.addr[i] < 0x10) Serial.print("0");
        Serial.print(mac.addr[i], HEX);
        if (i > 0) Serial.print(":");
      }
      Serial.println();

      // Détection appui long
      uint32_t t0 = millis();
      uint32_t currentPin = (activeBtn == 1) ? BTN1 : (activeBtn == 2 ? BTN2 : BTN3);
      bool longPressTriggered = false;

      while (!digitalRead(currentPin)) {
        if (millis() - t0 >= LONG_PRESS_MS) {
          uint8_t longCode = (activeBtn == 1) ? 5 : (activeBtn == 2 ? 6 : 4);
          majBLE(longCode);
          Serial.print("Long press -> code ");
          Serial.println(longCode);
          longPressTriggered = true;
          delay(200);
          while (!digitalRead(currentPin)) { delay(10); } // Attendre relâchement
          break;
        }
        delay(10);
      }

      if (!longPressTriggered) {
        majBLE(activeBtn);
        Serial.print("Short press -> code ");
        Serial.println(activeBtn);
        delay(200);
      }

      // Stopper l'advertising au lieu d'envoyer un code 0
      // Le récepteur détecte le changement d'état via dernierEtat
      Bluefruit.Advertising.stop();
      delay(50);

      // Envoyer le code neutre pour reset du dernierEtat côté récepteur
      majBLE(0);
      delay(100);
      Bluefruit.Advertising.stop();

      dernierClic = millis();
    }

    delay(10);
  }

  // ================= DEEP SLEEP =================
  Serial.println("\nZzz... Deep Sleep.");
  delay(100);

  Bluefruit.Advertising.stop();

  // Configurer les 3 boutons comme sources de réveil (SENSE LOW)
  pinMode(BTN1, INPUT);
  pinMode(BTN2, INPUT);
  pinMode(BTN3, INPUT);

  uint32_t hwPins[3] = {g_ADigitalPinMap[BTN1], g_ADigitalPinMap[BTN2], g_ADigitalPinMap[BTN3]};
  for (int i = 0; i < 3; i++) {
    nrf_gpio_cfg_sense_input(hwPins[i], NRF_GPIO_PIN_PULLUP, NRF_GPIO_PIN_SENSE_LOW);
  }

  NRF_POWER->SYSTEMOFF = 1;
}

void loop() {
  // Jamais atteint
}
