#include <bluefruit.h>
#include "nrf_gpio.h"

#define BTN1 D0 // Team 1
#define BTN2 D1 // Team 2
#define BTN3 D2 // Undo

#define LONG_PRESS_MS 3000 // 3 secondes
#define ACTIVE_WINDOW 2000 // Temps d'éveil (2 secondes) après le dernier clic

void majBLE(uint8_t code) {
  Bluefruit.Advertising.stop();
  Bluefruit.Advertising.clearData();
  Bluefruit.Advertising.addFlags(BLE_GAP_ADV_FLAGS_LE_ONLY_GENERAL_DISC_MODE);
  Bluefruit.Advertising.addName();
  Bluefruit.Advertising.addData(BLE_GAP_AD_TYPE_MANUFACTURER_SPECIFIC_DATA, &code, 1);
  Bluefruit.Advertising.setInterval(32, 32); 
  Bluefruit.Advertising.start(0);
}

void setup() {
  uint32_t latch = NRF_P0->LATCH;
  NRF_P0->LATCH = latch; // On efface la mémoire matérielle

  pinMode(BTN1, INPUT_PULLUP);
  pinMode(BTN2, INPUT_PULLUP);
  pinMode(BTN3, INPUT_PULLUP);

  Bluefruit.begin();
  Bluefruit.setTxPower(4);
  Bluefruit.setName("NRF_BTN");
  Bluefruit.autoConnLed(false);

  // Chronomètre pour savoir quand s'endormir
  uint32_t dernierClic = millis(); 

  // =========================================================================
  // LA BOUCLE D'ÉVEIL : La carte reste active 2 secondes après chaque action
  // =========================================================================
  while (millis() - dernierClic < ACTIVE_WINDOW) {
    
    uint8_t activeBtn = 0;
    
    // On lit les boutons (et on utilise le LATCH uniquement au tout premier passage)
    if      (!digitalRead(BTN1) || (latch & (1 << g_ADigitalPinMap[BTN1]))) activeBtn = 1;
    else if (!digitalRead(BTN2) || (latch & (1 << g_ADigitalPinMap[BTN2]))) activeBtn = 2;
    else if (!digitalRead(BTN3) || (latch & (1 << g_ADigitalPinMap[BTN3]))) activeBtn = 3;

    latch = 0; // On vide le latch pour ne pas qu'il déclenche en boucle !

    if (activeBtn != 0) {
      uint32_t t0 = millis();
      uint32_t currentPin = (activeBtn == 1) ? BTN1 : (activeBtn == 2 ? BTN2 : BTN3);
      bool longPressTriggered = false;

      while (!digitalRead(currentPin)) {
        if (millis() - t0 >= LONG_PRESS_MS) {
          uint8_t longCode = (activeBtn == 1) ? 5 : (activeBtn == 2 ? 6 : 4);
          majBLE(longCode);
          longPressTriggered = true;
          
          delay(200); // Déroulé raccourci ! (200ms suffisent largement à l'ESP32)
          while (!digitalRead(currentPin)) { delay(10); } 
          break; 
        }
        delay(10);
      }

      if (!longPressTriggered) {
        majBLE(activeBtn); // Envoie 1, 2 ou 3
        delay(200);        // Temps réduit à 200ms pour plus de nervosité
      }

      // Le doigt est relâché, on envoie le code 0
      majBLE(0);
      delay(100); // On laisse juste 100ms à l'ESP32 pour capter le relâchement

      // ACTION TERMINÉE : On remet le chronomètre de sommeil à zéro !
      dernierClic = millis(); 
    }
    
    delay(10); // Petite pause pour stabiliser la boucle
  }

  // =========================================================================
  // FIN DE LA FENÊTRE D'ÉVEIL (2 secondes sans rien faire) -> DEEP SLEEP
  // =========================================================================
  Bluefruit.Advertising.stop();
  pinMode(BTN1, INPUT);
  pinMode(BTN2, INPUT);
  pinMode(BTN3, INPUT);

  uint32_t hwPins[3] = {g_ADigitalPinMap[BTN1], g_ADigitalPinMap[BTN2], g_ADigitalPinMap[BTN3]};
  for (int i = 0; i < 3; i++) {
    nrf_gpio_cfg_sense_input(hwPins[i], NRF_GPIO_PIN_PULLUP, NRF_GPIO_PIN_SENSE_LOW);
  }

  sd_softdevice_disable();
  NRF_POWER->SYSTEMOFF = 1;
}

void loop() {}
